class Solution {
public:
    int maxDistance(vector<int>& colors) {
        int n = colors.size();
        int ans = 0;
        for(int i  = 0;i<n-1;i++){
            int val = 0;
            for(int j = i+1;j<n;j++){
                if(colors[i]!=colors[j]) val = abs(j-i);
            }
            ans  =  max(ans,val);
        }
        return ans;
    }
};
