class Solution {
public:
    vector<int> survivedRobotsHealths(vector<int>& positions, vector<int>& healths, string directions) {
        int n = positions.size();
        vector<int> ans;
        unordered_map<int,int> healthmpp;
        unordered_map<int,char> dirmpp;
        for(int i = 0; i < n; i++){
            healthmpp[positions[i]] = healths[i];
            dirmpp[positions[i]] = directions[i];
        }
        vector<int> sortedPos = positions;
        sort(sortedPos.begin(), sortedPos.end());
        stack<int> st;
        for(int i = 0; i < n; i++){
            int currPos = sortedPos[i];
            if(dirmpp[currPos] == 'R'){
                st.push(currPos);
                continue;
            }
            while(!st.empty() && healthmpp[currPos] > 0){
                int pos = st.top();
                if(healthmpp[pos] == healthmpp[currPos]){
                    st.pop();
                    healthmpp[currPos] = 0;
                    healthmpp[pos] = 0;
                    break;
                }
                else if(healthmpp[pos] > healthmpp[currPos]){
                    healthmpp[pos]--;
                    healthmpp[currPos] = 0;
                    break;
                }
                else{
                    healthmpp[currPos]--;
                    healthmpp[pos] = 0;
                    st.pop();
                    continue;
                }
            }
        }
        for(int i = 0; i < n; i++){
            if(healthmpp[positions[i]] > 0){
                ans.push_back(healthmpp[positions[i]]);
            }
        }
        return ans;
    }
};
